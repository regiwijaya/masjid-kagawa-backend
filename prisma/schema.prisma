generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  category    String?
  date        DateTime
  description String?
  imageUrl    String?
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
}

model Activity {
  id          Int      @id @default(autoincrement())
  title       String

  // 🔥 NEW (CORE)
  type        String   @default("kegiatan") // kegiatan | kajian

  category    String?  @default("Kegiatan")
  date        DateTime
  startTime   String?
  endTime     String?

  // 🔥 untuk kajian
  ustadz      String?

  location    String?
  description String? @db.LongText
  imageUrl    String?

  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)

  createdBy   Int?
  updatedBy   Int?

  createdAt   DateTime @default(now())
}

model Kajian {
  id          Int      @id @default(autoincrement())
  title       String
  category    String?  @default("Lainnya")
  ustadz      String?
  date        DateTime
  time        String?
  location    String?  @default("Masjid Kagawa")
  description String?
  imageUrl    String?
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique

  excerpt     String   @db.Text
  content     String   @db.LongText

  imageUrl    String?
  category    String?
  author      String?

  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)

  createdBy   Int?
  updatedBy   Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now()) // 🔥 FIX
}

model AboutSetting {
  id                Int      @id @default(autoincrement())
  heroTitle         String?
  heroSubtitle      String?
  heroImageUrl      String?
  historyTitle      String?
  historyText       String? @db.Text
  historyImageUrl   String?
  visionTitle       String?
  visionText        String? @db.Text
  missionTitle      String?
  missionItems      Json?
  leaders           Json?
  footerDescription String? @db.Text
  address           String?
  email             String?
  phone             String?
  mapEmbedUrl       String? @db.Text
  imamDuty          String?
  muadzinDuty       String?
  social            Json?
  updatedBy         Int?
  createdAt         DateTime @default(now())
}

model Contact {
  id          Int      @id @default(autoincrement())
  type        String
  name        String?
  contact     String?
  message     String
  category    String?
  isAnonymous Boolean  @default(false)
  isRead      Boolean  @default(false)

  createdAt   DateTime @default(now())
}

model DonationSetting {
  id                         Int      @id @default(autoincrement())
  bankJapanName              String?
  bankJapanAccountName       String?
  bankJapanAccountNumber     String?
  bankJapanBranch            String?
  bankIndonesiaName          String?
  bankIndonesiaAccountName   String?
  bankIndonesiaAccountNumber String?
  bankIndonesiaBranch        String?
  qrisImageUrl               String?
  donationNote               String?
  confirmationText           String?
  confirmationLink           String?
  updatedBy                  Int?
  createdAt                  DateTime @default(now())
}

model IqamahSetting {
  id        Int      @id @default(autoincrement())
  subuh     String?
  zuhur     String?
  asar      String?
  maghrib   String?
  isya      String?
  createdAt DateTime @default(now())
}