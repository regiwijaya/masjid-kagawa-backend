generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model aboutsetting {
  id                Int      @id @default(autoincrement())
  heroTitle         String?
  heroSubtitle      String?
  heroImageUrl      String?
  historyTitle      String?
  historyText       String?  @db.Text
  historyImageUrl   String?
  visionTitle       String?
  visionText        String?  @db.Text
  missionTitle      String?
  missionItems      String?  @db.LongText
  leaders           String?  @db.LongText
  footerDescription String?  @db.Text
  address           String?
  email             String?
  phone             String?
  mapEmbedUrl       String?  @db.Text
  imamDuty          String?
  muadzinDuty       String?
  social            String?  @db.LongText
  updatedBy         Int?
  createdAt         DateTime @default(now())
}

model activity {
  id          Int      @id @default(autoincrement())
  title       String
  category    String?  @default("Kegiatan")
  date        DateTime
  startTime   String?
  endTime     String?
  location    String?
  description String?  @db.LongText
  imageUrl    String?
  isPublished Boolean  @default(true)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
  isFeatured  Boolean  @default(false)
  type        String   @default("kegiatan")
  ustadz      String?
}

model admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique(map: "Admin_email_key")
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model announcement {
  id          Int      @id @default(autoincrement())
  title       String
  category    String?
  date        DateTime
  description String?
  imageUrl    String?
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
}

model contact {
  id          Int      @id @default(autoincrement())
  type        String
  name        String?
  contact     String?
  message     String
  category    String?
  isAnonymous Boolean  @default(false)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model donationsetting {
  id                         Int      @id @default(autoincrement())
  bankJapanName              String?
  bankJapanAccountName       String?
  bankJapanAccountNumber     String?
  bankJapanBranch            String?
  bankIndonesiaName          String?
  bankIndonesiaAccountName   String?
  bankIndonesiaAccountNumber String?
  bankIndonesiaBranch        String?
  qrisImageUrl               String?
  donationNote               String?
  confirmationText           String?
  confirmationLink           String?
  updatedBy                  Int?
  createdAt                  DateTime @default(now())
}

model donationconfirmation {
  id              Int      @id @default(autoincrement())
  donorName       String?
  isAnonymous     Boolean  @default(false)
  email           String?
  contact         String?
  currency        String   @default("JPY")
  amount          String?
  donationPurpose String
  otherPurpose    String?
  paymentMethod   String?
  proofImageUrl   String?
  message         String?  @db.Text
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
}

model iqamahsetting {
  id        Int      @id @default(autoincrement())
  subuh     String?
  zuhur     String?
  asar      String?
  maghrib   String?
  isya      String?
  createdAt DateTime @default(now())
}

model kajian {
  id          Int      @id @default(autoincrement())
  title       String
  category    String?  @default("Lainnya")
  ustadz      String?
  date        DateTime
  time        String?
  location    String?  @default("Masjid Kagawa")
  description String?
  imageUrl    String?
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
}

model post {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique(map: "Post_slug_key")
  excerpt     String   @db.Text
  content     String   @db.LongText
  imageUrl    String?
  category    String?
  author      String?
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdBy   Int?
  updatedBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
}